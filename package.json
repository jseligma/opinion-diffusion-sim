{
  "name": "opinion-diffusion-sim",
  "version": "0.1.0",
  "private": true,
  "description": "Opinion diffusion simulator scaffold with NGL/ORL DSL support",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
